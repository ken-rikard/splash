# NVE HydAPI key — free registration at https://hydapi.nve.no/User/Account/Register
NVE_API_KEY=

# Port for the Splash server (default: 3000)
# PORT=3000

# Scrape schedule (default: every 15 minutes)
# SCRAPE_SCHEDULE=*/15 * * * *
# SCRAPE_SCHEDULE_TZ=UTC

# Retry configuration
# SCRAPE_RETRIES=3
# SCRAPE_RETRY_MIN_TIMEOUT=2000
# SCRAPE_RETRY_MAX_TIMEOUT=60000

# Stale data threshold in minutes (default: 30)
# SCRAPE_STALE_WINDOW_MINUTES=30
